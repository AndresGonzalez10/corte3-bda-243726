# ARCHIVO DE EJEMPLO (.env.example)
# Credenciales de Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=tu_contraseña_segura_aqui
POSTGRES_DB=clinica_vet

# Configuración Interna de Red (Docker)
PG_HOST=postgres
PG_PORT_INTERNAL=5432
REDIS_HOST=redis
REDIS_PORT_INTERNAL=6379
API_PORT_INTERNAL=4000
FRONTEND_PORT_INTERNAL=3000

# Puertos Expuestos a tu computadora
PG_PORT_EXTERNAL=5432
REDIS_PORT_EXTERNAL=6379
API_PORT_EXTERNAL=4000
FRONTEND_PORT_EXTERNAL=3001

# Variables del Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000/api